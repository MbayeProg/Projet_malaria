### Distribution des nombres de tests TDR moyens entre 2008 et 2022 par region
dev.new(width= 10, height= 7)
df |> select(V2, V8) |>
mutate(V2 = as.factor(V2)) |>
group_by(V2) |>
summarise(moyen = mean(V8)) |>
ggplot(aes( x = V2,
y = moyen)
) +
geom_bar( col= "#616a6b",
stat = "identity",
fill = "#fad7a0") +
coord_flip() +
labs( x = "Regions",
y = "Moyenne des nombres de tests TDR entre 2008 et 2022",
title = "Distribution des nombres de tests TDR moyens entre 2008 et 2022 par region",
) +
theme_minimal()
dev.new(width= 10, height= 7)
df |> select(V2, V11) |>
mutate(V2 = as.factor(V2)) |>
group_by(V2) |>
summarise(moyen = mean(V11)) |>
ggplot(aes( x = V2,
y = moyen,
color = species)
) +
geom_bar( col= "#616a6b",
stat = "identity",
fill = "#fad7a0") +
coord_flip() +
labs( x = "Regions",
y = "Moyenne taux de tests TDR realises (rapporte au cas suspects)",
