# INSTALLATION DES LIBRAIRIES
for (pkg in packages) {
install.packages(pkg, dependencies = TRUE)
}
rbinom(n =0.25 , size =10 , prob = 1/3) # genere aleatoirement les realisations de X~>B(n, p)
rbinom(n = 5 , size =10 , prob = 1/3) # genere aleatoirement les realisations de X~>B(n, p)
qbinom(p =0.25 , size =10 , prob = 1/3) # fonction quantile
mean(vect)
vect = rpois(n = 100 , lambda = 5) # Generateur de valeurs aleatoires
mean(vect)
vect = rpois(n = 1000 , lambda = 5) # Generateur de valeurs aleatoires
mean(vect)
vect = rpois(n = 1000 , lambda = 5) # Generateur de valeurs aleatoires
mean(vect)
# Utilisation de sample pour creer un vecteur de loi uniforme
sample(x = 1:5, size = 20, replace = F)
# Utilisation de sample pour creer un vecteur de loi uniforme
sample(x = 1:5, size = 20, replace = T)
sample(x = 1:10, size = 5, replace = F) # Tirage sans remise "replace= F"
sample(x = 1:5, size = 15, replace = T, prob = c(1/5, 1/5, 1/5, 1/5, 1/5)) # Tirage d'une loi uniforme discrete
# Donner les quantiles Q_1 , Q_2 et Q_3
qunif(p = 0.25, min =0 , max = 1)
# Donner les quantiles Q_1 , Q_2 et Q_3
Q_1 = qunif(p = 0.25, min =0 , max = 1)
Q_2 = qunif(p = 0.5, min =0 , max = 1)
Q_3 = qunif(p = 0.75, min =0 , max = 1)
print(Q_1, Q_2, Q_3)
# Donner les quantiles Q_1 , Q_2 et Q_3
Q_1 = qunif(p = 0.25, min =0 , max = 1)
Q_2 = qunif(p = 0.5, min =0 , max = 1)
Q_3 = qunif(p = 0.75, min =0 , max = 1)
print(Q_1)
print(Q_2)
print(Q_3)
# 2. Soit X~>U [1, 3] de fonction de repartition F. Donner F(2)
F = punif(q = 2, min=1, max=3)
print(F)
# 3. Les 3eme et 7eme deciles de U [1, 4]
D_1 = qunif(p = 1/10, min = 1, max = 4)
D_7 = qunif(p = 7/10, min = 1, max = 4)
print(D_1)
print(D_7)
# 4. Tracee de la densite de probabilité de la loi U [0, 1]
curve(expr = dunif(x, 0, 1), from = 0, to = 1, n = 100, add = T)
# 4. Tracee de la densite de probabilité de la loi U [0, 1]
curve(expr = dunif(x, 0, 1), from = 0, to = 1, n = 100)
# 4. Tracee de la densite de probabilité de la loi U [0, 1]
curve(expr = dunif(x, 0, 1), from = 0, to = 1)
